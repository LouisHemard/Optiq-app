# Port du serveur
PORT=3002

# Base de données PostgreSQL
# En prod : récupérer l'URL fournie par Railway
DATABASE_URL=postgresql://user:password@host:5432/optiq

# Auth JWT — générer avec : openssl rand -base64 64
JWT_SECRET=change-this-to-a-strong-random-secret

# URL publique du backend (pour construire les URLs des images locales)
# En prod : https://ton-backend.railway.app
APP_URL=http://localhost:3002

# Stockage des images (Supabase Storage)
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...
SUPABASE_BUCKET=Picture

# Monitoring Sentry (optionnel)
# Créer un projet sur sentry.io pour obtenir le DSN
SENTRY_DSN=https://xxx@oXXX.ingest.sentry.io/XXX
